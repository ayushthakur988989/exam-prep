# Server Port Configuration
PORT=5000

# MongoDB Database Connection String
# Replace 127.0.0.1 with your actual host or MongoDB Atlas URI if needed.
MONGO_URI=mongodb://127.0.0.1:27017/exam_prep

# Gmail credentials for sending OTP emails
# Use your Gmail address and an App Password (NOT your real password)
# Generate App Password: Google Account > Security > 2-Step Verification > App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password_here
